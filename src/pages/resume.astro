---
import BaseLayout from "../layouts/BaseLayout.astro";

const resumeUrl = "/Adam%20Koziorz%20Resume%20-%20S26.pdf";
---

<BaseLayout title="Resume" sideBarActiveItemID="resume">
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div class="text-3xl font-bold">My Resume</div>
    <div class="flex gap-2">
      <a
        href={resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-sm btn-outline"
      >
        Open in new tab
      </a>
      <a
        href={resumeUrl}
        download="Adam Koziorz Resume - S26.pdf"
        class="btn btn-sm btn-primary"
      >
        Download PDF
      </a>
    </div>
  </div>

  <div
    id="resume-viewer"
    class="rounded-lg border border-base-300 shadow-sm overflow-hidden bg-base-200"
  >
    <p
      id="resume-status"
      class="px-4 py-8 text-center text-sm text-base-content/60"
    >
      Loading resume preview…
    </p>
    <div id="resume-pages" class="flex flex-col gap-3"></div>
  </div>

  <noscript>
    <div class="mt-4 rounded-lg border border-base-300 overflow-hidden shadow-sm">
      <iframe
        src={resumeUrl}
        title="Adam Koziorz Resume"
        class="w-full"
        style="aspect-ratio: 8.5 / 11; min-height: 600px;"
      ></iframe>
    </div>
  </noscript>
</BaseLayout>

<script>
  import * as pdfjsLib from "pdfjs-dist";
  import workerUrl from "pdfjs-dist/build/pdf.worker.min.mjs?url";

  pdfjsLib.GlobalWorkerOptions.workerSrc = workerUrl;

  const PDF_URL = "/Adam%20Koziorz%20Resume%20-%20S26.pdf";
  const MAX_DPR = 2; // cap pixel density so canvases don't get huge

  type Entry = {
    page: any;
    canvas: HTMLCanvasElement;
    renderTask: any;
    lastWidth: number;
  };

  let entries: Entry[] = [];
  let resizeTimer: number | undefined;

  function renderPage(entry: Entry, pagesEl: HTMLElement) {
    const cssWidth = pagesEl.clientWidth;
    if (!cssWidth) return; // not laid out / hidden — a later resize will retry

    const dpr = Math.min(window.devicePixelRatio || 1, MAX_DPR);
    const base = entry.page.getViewport({ scale: 1 });
    const viewport = entry.page.getViewport({
      scale: (cssWidth / base.width) * dpr,
    });

    // A canvas can't be in two render passes at once — cancel any in flight.
    if (entry.renderTask) entry.renderTask.cancel();

    entry.canvas.width = Math.floor(viewport.width);
    entry.canvas.height = Math.floor(viewport.height);
    entry.canvas.style.width = "100%";
    entry.canvas.style.height = "auto";
    entry.lastWidth = cssWidth;

    const ctx = entry.canvas.getContext("2d");
    if (!ctx) return;

    const task = entry.page.render({ canvasContext: ctx, viewport });
    entry.renderTask = task;
    task.promise.catch((err: any) => {
      if (err?.name !== "RenderingCancelledException") console.error(err);
    });
  }

  async function setup() {
    const pagesEl = document.getElementById("resume-pages");
    const statusEl = document.getElementById("resume-status");
    if (!pagesEl || !statusEl) return;

    // Guard: only render once per DOM (handles double-fire on first load).
    if (pagesEl.dataset.resumeRendered) return;
    pagesEl.dataset.resumeRendered = "true";

    entries = [];
    try {
      const pdf = await pdfjsLib.getDocument(PDF_URL).promise;
      for (let n = 1; n <= pdf.numPages; n++) {
        const page = await pdf.getPage(n);
        const canvas = document.createElement("canvas");
        canvas.className = "block w-full bg-white";
        pagesEl.appendChild(canvas);
        const entry: Entry = { page, canvas, renderTask: null, lastWidth: 0 };
        entries.push(entry);
        renderPage(entry, pagesEl);
      }
      statusEl.style.display = "none";
    } catch (err) {
      console.error("Resume preview failed to render:", err);
      statusEl.textContent =
        "The preview couldn't load — use the buttons above to view or download the resume.";
    }
  }

  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(() => {
      const pagesEl = document.getElementById("resume-pages");
      if (!pagesEl) return;
      for (const entry of entries) {
        if (pagesEl.clientWidth !== entry.lastWidth) renderPage(entry, pagesEl);
      }
    }, 150);
  });

  // Fires on every navigation when ViewTransitions is on...
  document.addEventListener("astro:page-load", setup);
  // ...and this covers the plain (no-ViewTransitions) initial load.
  setup();
</script>
